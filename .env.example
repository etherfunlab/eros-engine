# eros-engine .env.example

# Postgres — shared with eros-gateway (see project memory). eros-engine
# reads/writes the `engine` schema only.
DATABASE_URL=postgres://postgres:<password>@<host>:5432/postgres

# OpenRouter (chat completions). Same key works for both apps.
OPENROUTER_API_KEY=sk-or-...

# Supabase project — same as eros-gateway.
SUPABASE_URL=https://<project-ref>.supabase.co
# JWT secret from Supabase Dashboard → Project Settings → API → JWT Secret.
# eros-gateway does not currently verify JWTs; eros-engine does, so this
# secret must match what Supabase signs tokens with.
SUPABASE_JWT_SECRET=

# Voyage embeddings (voyage-3-lite, 512-dim).
VOYAGE_API_KEY=pa-...

# Server
BIND_ADDR=0.0.0.0:8080
EXPOSE_AFFINITY_DEBUG=true
EMA_INERTIA=0.8
MODEL_CONFIG_PATH=examples/model_config.toml
RUST_LOG=info
