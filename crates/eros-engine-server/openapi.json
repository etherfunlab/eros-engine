    "securitySchemes": {
      "bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Supabase JWT bearer token"
      },
      "hmac_signature": {
        "type": "apiKey",
        "in": "header",
        "name": "X-S2S-Signature",
        "description": "HMAC-SHA256 signature over the canonical signing string. Requires companion `X-S2S-Timestamp` header. See auth::s2s for the canonical layout."
      }
    }
