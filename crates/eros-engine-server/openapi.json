          "patience",
          "tension",
          "ghost_streak",
          "total_ghosts",
          "updated_at"
        ],
        "properties": {
          "ghost_streak": {
            "type": "integer",
            "format": "int32"
          },
          "intimacy": {
            "type": "number",
            "format": "double"
          },
          "intrigue": {
            "type": "number",
            "format": "double"
          },
          "patience": {
            "type": "number",
            "format": "double"
          },
          "relationship_label": {
            "type": [
              "string",
              "null"
            ]
          },
          "tension": {
            "type": "number",
            "format": "double"
          },
          "total_ghosts": {
            "type": "integer",
            "format": "int32"
          },
          "trust": {
            "type": "number",
            "format": "double"
          },
          "updated_at": {
            "type": "string"
          },
          "warmth": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "BffAffinityDelta": {
        "type": "object",
        "required": [
          "event_id",
          "event_type",
